{
  "name": "chenmobuys/easyexcel",
  "type": "library",
  "license": "MIT",
  "description": "Easy excel library for php.",
  "keywords": [
    "php",
    "office",
    "msexcel",
    "phpexcel",
    "excel",
    "sheet",
    "worksheet",
    "spreadsheet",
    "reader",
    "writer",
    "csv",
    "ods",
    "xls",
    "xlsx"
  ],
  "authors": [
    {
      "name": "Chenmobuys",
      "email": "chenmobuys@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "EasyExcel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "EasyExcelTests\\": "tests/"
    }
  },
  "require": {
    "php": "^7.1||^8.0",
    "ext-xml": "*",
    "ext-zip": "*",
    "ext-libxml": "*",
    "ext-fileinfo": "*",
    "ext-simplexml": "*",
    "ext-xmlreader": "*",
    "ext-xmlwriter": "*"
  },
  "suggest": {
    "ext-iconv": "Parsing csv xls files requires encoding conversion. ",
    "ext-mbstring": "Parsing csv xls files requires encoding conversion."
  },
  "require-dev": {
    "phpunit/phpunit": "^5.7||^6.5||^7.5||^8.5||^9.5"
  }
}
